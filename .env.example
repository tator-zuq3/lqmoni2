# === REQUIRED ===
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# === BLACKLIST (optional) ===
# Skip tokens with these names (comma-separated, case-insensitive)
# FILTER_NAMES=test,testing,aaa

# === VIP CHANNEL (optional) ===
# Second Telegram channel for VIP notifications
# VIP_CHAT_ID=-1001234567890

# Token names that trigger VIP (partial match, case-insensitive)
# VIP_NAMES=liquid

# Deployer addresses that trigger VIP
# VIP_DEPLOYERS=0xabc...,0xdef...

# Admin addresses that trigger VIP
# VIP_ADMINS=0xabc...

# Reward admin addresses that trigger VIP
# VIP_REWARD_ADMINS=0xabc...
